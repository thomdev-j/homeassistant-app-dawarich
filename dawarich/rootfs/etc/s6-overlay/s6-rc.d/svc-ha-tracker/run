#!/usr/bin/with-contenv bash

# HA Location Tracker → Dawarich bridge
#
# Pushes device_tracker location updates to Dawarich via the Overland API.
# Subscribes to HA's /api/stream for real-time state_changed events.

# Source bashio for logging, then disable set -e to prevent crash on errors
source /usr/lib/bashio/bashio.sh || true
set +e

HA_TRACKED_ENTITIES=$(cat /var/run/s6/container_environment/HA_TRACKED_ENTITIES 2>/dev/null)

if [ -z "$HA_TRACKED_ENTITIES" ]; then
  bashio::log.info "HA Tracker: not configured (set ha_tracked_entities in app config). Sleeping."
  exec sleep infinity
fi

# Wait for per-entity API keys directory (written by svc-dawarich after user creation)
# Falls back to legacy single api_key file for backward compatibility
while true; do
  if [ -d /data/dawarich/api_keys ] && [ "$(ls -A /data/dawarich/api_keys 2>/dev/null)" ]; then
    break
  elif [ -f /data/dawarich/api_key ] && [ -s /data/dawarich/api_key ]; then
    break
  fi
  bashio::log.info "HA Tracker: waiting for Dawarich API keys..."
  sleep 10
done
DAWARICH_API_KEY_FALLBACK=$(cat /data/dawarich/api_key 2>/dev/null || echo "")

if [ -z "$SUPERVISOR_TOKEN" ]; then
  bashio::log.error "HA Tracker: SUPERVISOR_TOKEN is not set! Cannot access HA API."
  exec sleep infinity
fi

# Build lookup set of tracked entity IDs and device names
declare -A IS_TRACKED
declare -A DEVICE_NAME
IFS=',' read -ra ENTITY_LIST <<< "$HA_TRACKED_ENTITIES"
for raw_entry in "${ENTITY_LIST[@]}"; do
  raw_entry=$(echo "$raw_entry" | xargs)
  [ -z "$raw_entry" ] && continue
  entity="${raw_entry%%:*}"
  entity=$(echo "$entity" | xargs)
  IS_TRACKED[$entity]=1
  DEVICE_NAME[$entity]=$(echo "$entity" | sed 's/device_tracker\.//')
done

HA_CLEAN_ENTITIES=$(echo "$HA_TRACKED_ENTITIES" | sed 's/:[^,]*//g')
bashio::log.info "HA Tracker: tracking entities [${HA_CLEAN_ENTITIES}]"

# Wait for Dawarich to be ready
until curl -sf http://localhost:3000 -o /dev/null 2>/dev/null; do
  bashio::log.info "HA Tracker: waiting for Dawarich to be ready..."
  sleep 10
done
bashio::log.info "HA Tracker: Dawarich is ready"

# Min distance in meters from last accepted point. Filters GPS drift when
# stationary (typical drift is 3-15m). 10m is the Overland app's default.
# Configurable via ha_min_distance in app config. Set to 0 to disable.
HA_MIN_DISTANCE=$(cat /var/run/s6/container_environment/HA_MIN_DISTANCE 2>/dev/null)
: "${HA_MIN_DISTANCE:=10}"

# --- Dedup state ---
declare -A LAST_LAT
declare -A LAST_LON

# Approximate distance in meters between two lat/lon points (Haversine).
haversine_m() {
  awk -v lat1="$1" -v lon1="$2" -v lat2="$3" -v lon2="$4" 'BEGIN {
    pi = 3.14159265358979
    dlat = (lat2 - lat1) * pi / 180
    dlon = (lon2 - lon1) * pi / 180
    a = sin(dlat/2)^2 + cos(lat1*pi/180) * cos(lat2*pi/180) * sin(dlon/2)^2
    printf "%.0f", 6371000 * 2 * atan2(sqrt(a), sqrt(1-a))
  }'
}

# Push a single location point to Dawarich.
# Args: entity_id state_json
# state_json is the HA state object (with .attributes.latitude etc.)
push_location() {
  local entity="$1" state_json="$2"

  local lat lon
  lat=$(echo "$state_json" | jq -r '.attributes.latitude // empty')
  lon=$(echo "$state_json" | jq -r '.attributes.longitude // empty')
  [ -z "$lat" ] || [ -z "$lon" ] && return 1

  # Exact coordinate dedup — skip if identical to last pushed position.
  # Catches non-location state changes (battery, connectivity).
  if [ "$lat" = "${LAST_LAT[$entity]:-}" ] && [ "$lon" = "${LAST_LON[$entity]:-}" ]; then
    bashio::log.debug "HA Tracker: ${entity} coordinates unchanged, skipping"
    return 1
  fi

  # Distance gate — filter GPS drift when stationary.
  local prev_lat="${LAST_LAT[$entity]:-}"
  local prev_lon="${LAST_LON[$entity]:-}"
  if [ -n "$prev_lat" ] && [ -n "$prev_lon" ] && [ "$HA_MIN_DISTANCE" -gt 0 ] 2>/dev/null; then
    local dist
    dist=$(haversine_m "$prev_lat" "$prev_lon" "$lat" "$lon")
    if [ "$dist" -lt "$HA_MIN_DISTANCE" ] 2>/dev/null; then
      bashio::log.debug "HA Tracker: ${entity} moved ${dist}m < ${HA_MIN_DISTANCE}m, skipping"
      return 1
    fi
  fi

  # Point accepted — update last known position
  LAST_LAT[$entity]="$lat"
  LAST_LON[$entity]="$lon"

  local device_name="${DEVICE_NAME[$entity]}"
  local acc batt alt speed vacc
  acc=$(echo "$state_json" | jq -r '.attributes.gps_accuracy // .attributes.location_accuracy // empty')
  batt=$(echo "$state_json" | jq -r '.attributes.battery_level // empty')
  alt=$(echo "$state_json" | jq -r '.attributes.altitude // empty')
  speed=$(echo "$state_json" | jq -r '.attributes.speed // .attributes.velocity // empty')
  vacc=$(echo "$state_json" | jq -r '.attributes.vertical_accuracy // empty')
  local tst
  tst=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

  local props="{\"timestamp\":\"${tst}\",\"device_id\":\"${device_name}\""
  [ -n "$acc" ] && props="${props},\"horizontal_accuracy\":${acc}"
  [ -n "$alt" ] && props="${props},\"altitude\":${alt}"
  [ -n "$speed" ] && props="${props},\"speed\":${speed}"
  [ -n "$batt" ] && props="${props},\"battery_level\":${batt},\"battery_state\":\"unknown\""
  [ -n "$vacc" ] && props="${props},\"vertical_accuracy\":${vacc}"
  props="${props}}"

  local payload="{\"locations\":[{\"type\":\"Feature\",\"geometry\":{\"type\":\"Point\",\"coordinates\":[${lon},${lat}]},\"properties\":${props}}]}"

  local api_key=""
  if [ -f "/data/dawarich/api_keys/${entity}" ]; then
    api_key=$(cat "/data/dawarich/api_keys/${entity}")
  else
    api_key="$DAWARICH_API_KEY_FALLBACK"
  fi

  local http_code
  http_code=$(curl -s -o /dev/null -w "%{http_code}" \
    -X POST -H "Content-Type: application/json" \
    -d "$payload" \
    "http://localhost:3000/api/v1/overland/batches?api_key=${api_key}")

  if [ "$http_code" = "200" ] || [ "$http_code" = "201" ]; then
    bashio::log.info "HA Tracker: pushed ${entity} (${lat}, ${lon})"
    return 0
  else
    bashio::log.warning "HA Tracker: failed to push ${entity}, HTTP ${http_code}"
    return 1
  fi
}

# Fetch current state for all tracked entities via REST (one-time on startup
# before streaming begins, so we don't miss the initial position).
initial_fetch() {
  for entity in "${!IS_TRACKED[@]}"; do
    local response
    response=$(curl -s -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
      "http://supervisor/core/api/states/${entity}" 2>/dev/null)
    [ -z "$response" ] && continue
    echo "$response" | jq -e '.' > /dev/null 2>&1 || continue
    push_location "$entity" "$response"
  done
}

# Subscribe to HA's SSE stream for real-time state_changed events.
run_sse() {
  bashio::log.info "HA Tracker: connecting to HA event stream..."
  local sse_connected=false

  # curl -N disables output buffering so we get lines as they arrive.
  while IFS= read -r line; do
    if [ "$sse_connected" = false ]; then
      bashio::log.info "HA Tracker: connected — receiving real-time state changes"
      sse_connected=true
    fi

    # SSE format: "data: {json}" lines contain the event payload
    [[ "$line" != data:* ]] && continue

    local json="${line#data: }"
    local entity_id
    entity_id=$(echo "$json" | jq -r '.data.entity_id // empty' 2>/dev/null)

    # Skip if not one of our tracked entities
    [ -z "$entity_id" ] || [ -z "${IS_TRACKED[$entity_id]:-}" ] && continue

    local new_state
    new_state=$(echo "$json" | jq -c '.data.new_state // empty' 2>/dev/null)
    [ -z "$new_state" ] || [ "$new_state" = "null" ] && continue

    push_location "$entity_id" "$new_state"
  done < <(curl -N -s --connect-timeout 10 \
    -H "Authorization: Bearer ${SUPERVISOR_TOKEN}" \
    "http://supervisor/core/api/stream?restrict=state_changed" 2>/dev/null)

  if [ "$sse_connected" = false ]; then
    bashio::log.warning "HA Tracker: connection failed"
  fi
}

# =====================================================================
#  Main: fetch initial positions, then stream real-time updates
# =====================================================================

initial_fetch

while true; do
  run_sse
  bashio::log.info "HA Tracker: stream disconnected, reconnecting in 5s..."
  sleep 5
done
